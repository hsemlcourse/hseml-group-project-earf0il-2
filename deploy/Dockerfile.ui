# Streamlit UI: thin client that calls the FastAPI service.
FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        libgl1 \
        libglib2.0-0 \
        curl \
 && rm -rf /var/lib/apt/lists/*

COPY deploy/requirements.txt /app/requirements.txt
# UI image doesn't need tensorflow at runtime — drop it to keep the image small.
RUN pip install --upgrade pip \
 && grep -v "^tensorflow" /app/requirements.txt > /app/requirements-ui.txt \
 && pip install -r /app/requirements-ui.txt

COPY deploy /app/deploy

ENV PYTHONPATH=/app \
    API_URL=http://api:8000

EXPOSE 8501

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD curl -fsS http://localhost:8501/_stcore/health || exit 1

CMD ["streamlit", "run", "deploy/ui/app.py", \
     "--server.port=8501", "--server.address=0.0.0.0", \
     "--server.headless=true", "--browser.gatherUsageStats=false"]
